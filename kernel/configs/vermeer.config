# K70 (vermeer) 内核额外配置
# 基于 sm8550_defconfig，启用以下功能

# UEFI/EFI 支持（用于 rEFInd/EDK2 引导）
CONFIG_EFI_STUB=y
CONFIG_EFI=y
CONFIG_EFI_VARS=y
CONFIG_EFI_ESRT=y
CONFIG_EFI_RUNTIME_MAP=y
CONFIG_EFI_GENERIC_STUB=y
CONFIG_EFI_GENERIC_STUB_INITRD_CMDLINE_LOADER=y
CONFIG_EFI_GENERIC_STUB_BUILTIN_DTB=y

# 设备树内置支持
CONFIG_BUILD_ARM64_APPENDED_DTB_IMAGE=y
CONFIG_BUILD_ARM64_DTB_IMAGE_NAMES="sm8550-xiaomi-vermeer"

# 显示支持
CONFIG_DRM=y
CONFIG_DRM_MSM=y
CONFIG_DRM_MSM_DPU=y
CONFIG_DRM_MSM_DP=y
CONFIG_DRM_PANEL=y
CONFIG_DRM_PANEL_XIAOMI_VERMEER=y

# 触摸
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_TOUCHSCREEN_GOODIX=y
CONFIG_TOUCHSCREEN_GOODIX_GT9916=y

# 电池/充电
CONFIG_BATTERY_BQ27XXX=y
CONFIG_CHARGER_BQ25890=y
CONFIG_CHARGER_QCOM_SMB5=y
CONFIG_FUEL_GAUGE_QCOM_PMIC=y

# 音频
CONFIG_SND_SOC=y
CONFIG_SND_SOC_QCOM=y
CONFIG_SND_SOC_QCOM_APM=y
CONFIG_SND_SOC_QCOM_APM_DAI=y
CONFIG_SND_SOC_QCOM_APM_DAI_LINK=y
CONFIG_SND_SOC_QCOM_Q6ASM=y
CONFIG_SND_SOC_QCOM_Q6AFE=y
CONFIG_SND_SOC_QCOM_Q6ADM=y
CONFIG_SND_SOC_QCOM_SOUNDWIRE=y
CONFIG_SND_SOC_WSA883X=y

# UFS 4.0
CONFIG_SCSI_UFS_QCOM=y
CONFIG_SCSI_UFS_BSG=y
CONFIG_SCSI_UFS_CRYPTO=y
CONFIG_SCSI_UFS_HPB=y

# PCIe / WiFi
CONFIG_PCIE_QCOM=y
CONFIG_PCIE_QCOM_EP=y
CONFIG_ATH11K=y
CONFIG_ATH11K_PCI=y
CONFIG_WCN6855=y

# USB
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_QCOM=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_F_UAC2=y
CONFIG_USB_CONFIGFS_F_MIDI=y
CONFIG_USB_CONFIGFS_F_HID=y
CONFIG_USB_CONFIGFS_F_UVC=y
CONFIG_TYPEC=y
CONFIG_TYPEC_TCPM=y
CONFIG_TYPEC_UCSI=y

# 相机
CONFIG_VIDEO_QCOM_CAMSS=y
CONFIG_VIDEO_QCOM_IRIS=y

# 指纹
CONFIG_SPI=y
CONFIG_SPI_QUP=y
CONFIG_SPI_QCOM_GENI=y

# NFC
CONFIG_NFC=y
CONFIG_NFC_NCI=y
CONFIG_NFC_NCI_SPI=y
CONFIG_NFC_PN533=y
CONFIG_NFC_PN533_I2C=y

# 传感器
CONFIG_IIO=y
CONFIG_IIO_BUFFER=y
CONFIG_IIO_TRIGGERED_BUFFER=y
CONFIG_INV_MPU6050_IIO=y
CONFIG_AK09911=y

# 振动
CONFIG_INPUT_GPIO_VIBRA=y

# LED
CONFIG_LEDS_GPIO=y
CONFIG_LEDS_TRIGGER_HEARTBEAT=y

# 温度监控
CONFIG_THERMAL=y
CONFIG_THERMAL_GOV_STEP_WISE=y
CONFIG_QCOM_TSENS=y
CONFIG_QCOM_SPMI_ADC_TM5=y

# 电源管理
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_ARM_QCOM_CPUFREQ_HW=y
CONFIG_ARM_QCOM_CPUFREQ_NVMEM=y
CONFIG_INTERCONNECT_QCOM_SM8550=y
CONFIG_DEVFREQ_GOV_SIMPLE_ONDEMAND=y
CONFIG_DEVFREQ_GOV_PERFORMANCE=y

# 调试
CONFIG_DEBUG_FS=y
CONFIG_DYNAMIC_DEBUG=y
CONFIG_DEBUG_KERNEL=y
CONFIG_DEBUG_LL=y
CONFIG_EARLY_PRINTK=y
